{
  "manifest_version": 3,
  "name": "Lyrics on Screen",
  "version": "1.3",
  "description": "Sends YouTube / YouTube Music captions to the desktop overlay daemon.",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://music.youtube.com/*"],
      "js": ["inject_raf.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content_youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content_ytmusic.js"],
      "run_at": "document_idle"
    }
  ]
}
